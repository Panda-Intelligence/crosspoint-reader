# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# QEMU build cache (Espressif fork, built by scripts/build-qemu.sh)
.qemu-cache/

# Cargo target dirs (src-tauri target is gitignored by Tauri's own setup;
# headless target needs explicit exclusion)
headless/target/

# User-supplied firmware fixtures (binaries are kept out of git)
firmware-fixtures/*.bin
firmware-fixtures/*.elf
!firmware-fixtures/.gitkeep

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
