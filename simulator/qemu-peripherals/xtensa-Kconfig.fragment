# Add the following two lines to the existing `config XTENSA_ESP32S3`
# block in hw/xtensa/Kconfig. Activation goes via `select` from the SoC
# (not `default y if XTENSA_ESP32S3` from the device side, which would
# create a Kconfig cycle through `BITBANG_I2C select I2C` and `FT6336U_MOFEI
# depends on I2C`):
    select FT6336U_MOFEI
    select SSD1677_GDEQ0426
