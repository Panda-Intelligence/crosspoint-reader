# Murphy Mate — local environment overrides
#
# Copy this file to `.env.local` (gitignored) and fill in values from
# Google Cloud Console / GitHub OAuth App. When any value is missing,
# the corresponding sign-in button on the Login screen is disabled with
# a "Not configured" hint instead of failing at runtime.
#
# All keys MUST be prefixed `EXPO_PUBLIC_` — that's the only namespace
# Expo exposes to the JS bundle (everything else stays server-side).
#
# Bundle identifier (must match Google/GitHub OAuth app config):
#   ai.pandacat.app.murphy.mate
# GitHub PKCE redirect URI to register on github.com:
#   murphymate://auth/github

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GITHUB_CLIENT_ID=
